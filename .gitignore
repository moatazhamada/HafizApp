# Flutter / Dart / Pub
# ===========================================
.dart_tool/
.packages
.pub/
**/build/
.flutter-plugins
.flutter-plugins-dependencies
**/doc/api/
.metadata

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Test logs (local only)
test_error.log
test_output.log
test_results.log

# ===========================================
# Android / Gradle
# ===========================================
.gradle/
local.properties
**/.cxx/
**/captures/

# Keystore files (DO NOT COMMIT)
**/*.jks
**/*.keystore
android/app/keystore.jks
android/app/*.jks
keystore.properties

# QF API credentials (local only, keep secrets out of git)
.dart_defines.json
.dart_defines.production.json
.dart_defines.prelive.json
qf_credentials.properties
android/qf_credentials.properties

# Build artifacts

# ===========================================
# iOS / macOS / Xcode
# ===========================================
**/DerivedData/
**/*.xcuserstate
**/xcuserdata/
**/*.xcuserdatad/
**/xcshareddata/WorkspaceSettings.xcsettings
ios/Flutter/.last_build_id
ios/Flutter/Generated.xcconfig

# Lock files (regenerate per machine)
ios/Podfile.lock
macos/Podfile.lock

# ===========================================
# Fastlane
# ===========================================
android/fastlane/report.xml
android/fastlane/Preview.html
android/fastlane/screenshots/**/*.png
android/fastlane/test_output
android/fastlane/service-account.json
android/fastlane/Gemfile.lock

